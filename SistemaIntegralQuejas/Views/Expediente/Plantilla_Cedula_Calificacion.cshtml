@model List<SistemaIntegralQuejas.Controllers.ExpedienteController.cedulaCalificacion>

@{
    Layout = null;
}
<style>
    * {
        font-family: Arial;
    }

    .cedula-left {
        margin-left: 15%;
        width: 42%;
        float: left;
    }

    .cedula-right {
        width: 42%;
        float: left;
    }

    .cedula-completo {
        width: 100%;
        text-align: center;
        margin-bottom: 0px;
        float: left;
        margin-top: 0px;
    }

    .cedula-completo1 {
        width: 100%;
        text-align: center;
        margin-bottom: 0px;
        float: left
    }

    .linea {
        width: 100%;
        height: 2px;
        background-color: gray;
        float: left
    }

    .img-responsive {
        width: 25px;
        height: 30px;
    }

    .titulos {
        font-size: 15px;
    }

    .titulodoc {
        font-size: 20px;
    }

    .titulodocsec {
        font-size: 20px;
    }

    .cedula-completo table {
        width: 100%;
        margin-top: 0px;
    }

    .cedula-completo1 table {
        width: 100%;
    }


    .cedula-completo1 > th, td {
        vertical-align: top;
        text-align: center;
        width: 30%;
    }

    .cedula-completo > td {
        text-align: left;
        margin-top: 0px;
        padding-top: 0px;
        width: 30%;
    }

    .cedula-completo > th {
        margin-top: 0px;
        padding-top: 0px;
        width: 30%;
    }

    .cedula-completo-izquierda {
        margin-top: 15px;
        float: left;
        width: 100%;
    }

        .cedula-completo-izquierda p {
            font-style: normal;
            font-weight: 100;
            font-size: 18px;
        }

    .cedula-left p {
        font-style: normal;
        font-weight: 100;
        font-size: 15px;
        line-height: 1.0;
        margin-top: 0;
        margin-bottom: 10px;
    }

    .cedula-right p {
        font-style: normal;
        font-weight: 100;
        font-size: 15px;
        line-height: 1.0;
        margin-top: 0;
        margin-bottom: 10px;
    }

    .datosfinales {
        margin-top: 100px;
        text-align: center;
        float: left;
        width: 100%;
    }

        .datosfinales .left {
            text-align: center;
            float: left;
            width: 50%;
            text-transform: uppercase;
        }

        .datosfinales .rigth {
            text-align: center;
            float: left;
            width: 50%;
            text-transform: uppercase;
        }

    h5 {
        margin-top: 0;
        margin-bottom: 8px;
    }

        h5 P {
            line-height: 1.0;
            margin-top: 0;
            margin-bottom: 10px;
        }


    .NOEXP {
        text-align: center;
        margin-bottom: 15px;
    }

    .conclusion .pequenio {
        width: 12.5%;
    }

    .conclusion .grande {
        width: 25%;
    }
</style>

<body>
    @foreach (var itemp in Model)
    {
        <div class="container receipt-wrap" id="receipt-wrap">
            <div class="row rowpapa">
                <div class="receipt-main col-xs-12 col-sm-12 col-md-12">
                    <div class="row">
                        <div class="col-xs-2 col-sm-2 col-md-2">
                            <div class="receipt-left">
                            </div>
                        </div>
                        <div class="cedula-completo">
                            <h5 class="titulodoc">CÉDULA DE CALIFICACIÓN POR VISITADURÍA GENERAL</h5>
                            <div class="linea"></div>
                        </div>

                        <h5 class="NOEXP titulos"><b></b>@itemp.Expediente <p> ID: @itemp.id</p></h5>
                        <div class="cedula-left">
                            <h5 class="FOR titulos"><b>FECHA Y HORA DE REGISTRO:</b><p>@itemp.fecha_Hora_registro</p></h5>
                            <h5 class="FRVG titulos"><b>FECHA DE RECEPCIÓN EN VISITADURÍA:</b><p>@itemp.fecha_RFV</p></h5>
                            <h5 class="VI titulos"><b>VÍA DE INTERPOSICIÓN:</b><p>@itemp.VIA_ENTRADA   </p></h5>
                            <h5 class="MAT titulos"><b>MATERIA:</b><p>@itemp.materia   </p></h5>
                            <h5 class="LHV titulos"><b>LUGAR DONDE OCURRIERON LOS HECHOS:</b><p>@itemp.lugar_Hechos   </p></h5>
                        </div>
                        <div class="cedula-right">
                            <h5 class="FOR titulos"><b>FECHA TURNO ELECTRÓNICO A VISITADURÍA:</b><p>@itemp.fecha_Hora_turnoe   </p></h5>
                            <h5 class="FOR titulos"><b>FECHA TURNO ABOGADO(A):</b><p> @itemp.fecha_TA  </p></h5>
                            <h5 class="FOR titulos"><b>FECHA CALIFICACIÓN:</b><p> @itemp.fecha_calificacion  </p></h5>
                            <h5 class="PROG titulos"><b>PROGRAMA:</b><p> @itemp.programa  </p></h5>
                        </div>

                        <div class="cedula-completo1">
                            <h5 class="titulodocsec">PETICIONARIOS(AS)</h5>
                            <div class="linea"></div>
                            <table>
                                <thead>
                                <th>ID DEL PETICIONARIO(A)</th>
                                <th>TIPO DEL PETICIONARIO(A)</th>
                                <th>NOMBRE DEL PETICIONARIO(A)</th>
                                </thead>
                                <tbody>
                                    @* @foreach (var itemuser in @itemp.listpet)
                                {
                                <tr>
                                <td>@itemuser.id</td>
                                <td>@itemuser.tipopet (a)</td>
                                <td>@itemuser.nombrepet</td>
                                </tr>
                                } *@
                                    @if (itemp.listpet != null && itemp.listpet.Any())
                                    {
                                        foreach (var itemuser in itemp.listpet)
                                        {
                                            <tr>
                                                <td>@itemuser.id</td>
                                                <td>@itemuser.tipopet</td>
                                                <td>@itemuser.nombrepet</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="3">Aun no hay peticionarios calificados.</td></tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                        <div class="cedula-completo">
                            <h5 class="titulodocsec">AUTORIDAD(ES) / HECHOS VIOLATORIOS</h5>
                            <div class="linea"></div>
                            <table>
                                <thead>
                                <th>AUTORIDAD(ES)</th>
                                <th>HECHOS VIOLATORIOS</th>
                                <th>DERECHO HUMANO</th>
                                </thead>
                                <tbody>
                                    @* @foreach (var itemuser in @itemp.listauth)
                                {
                                <tr>
                                <td>@itemuser.autoridad</td>
                                <td>@itemuser.HV</td>
                                <td>@itemuser.DH</td>
                                </tr>
                                } *@
                                    @if (itemp.listauth != null && itemp.listauth.Any())
                                    {
                                        foreach (var itemuser in itemp.listauth)
                                        {
                                            <tr>
                                                <td>@itemuser.autoridad</td>
                                                <td>@itemuser.HV</td>
                                                <td>@itemuser.DH</td>
                                            </tr>
                                        }
                                    }
                                    else
                                    {
                                        <tr><td colspan="3">Aun no hay autoridades calificadas.</td></tr>
                                    }
                                </tbody>
                            </table>
                            <div class="linea"></div>
                        </div>

                        <div class="cedula-completo-izquierda">
                            <h5 class="FOR titulos"><b>HECHOS:</b><p>@itemp.hechos</p></h5>
                        </div>

                        <div class="cedula-completo conclusion">
                            <h5 class="titulodocsec">CONCLUSIÓN DEL EXPEDIENTE</h5>
                            <div class="linea"></div>
                            <table>
                                <thead>
                                    <tr>
                                        <th>FECHA</th>
                                        <th>CLAVE</th>
                                        <th>CAUSA</th>
                                        <th>ACTO RESTITUIDO</th>
                                        <th>OBSERVACIONES</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (itemp.listacasa == null || itemp.listacasa.Count <= 0)
                                    {
                                        <tr>
                                            <td><em>No aplica</em></td>
                                            <td><em>No aplica</em></td>
                                            <td><em>No aplica</em></td>
                                            <td><em>No aplica</em></td>
                                            <td><em>No aplica</em></td>
                                        </tr>
                                    }
                                    else
                                    {
                                        foreach (var itemuser in itemp.listacasa)
                                        {
                                            <tr>
                                                <td class="pequenio">@itemuser.fechac</td>
                                                <td class="pequenio">@itemuser.causac</td>
                                                <td class="grande">@itemuser.causacdesc</td>
                                                <td class="grande">@itemuser.acto_rest</td>
                                                <td class="grande">@itemuser.obs</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                            <div class="linea"></div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="datosfinales">
                <div class="left">
                    <p>@itemp.abogado</p>
                    <p><b>VISITADOR/A ADJUNTO/A</b></p>

                </div>
                <div class="rigth">
                    <p>@itemp.visitador</p>
                    <p><b>@itemp.visitaduría</b></p>
                </div>
            </div>
        </div>

    }
</body>