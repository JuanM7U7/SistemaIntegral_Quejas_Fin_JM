@model List<SistemaIntegralQuejas.Controllers.ExpedienteController.CedulaQuejas>

@{
    Layout = null;
}

<style>

    * {
        font-family: Arial;
    }

    .cedula-left {
        margin-left: 15%;
        width: 42%;
        float: left;
    }

    .cedula-right {
        width: 42%;
        float: left;
    }

    .cedula-completo {
        width: 100%;
        text-align: center;
        margin-bottom: 0px;
        float: left
    }

    .cedula-completo1 {
        width: 100%;
        text-align: center;
        margin-bottom: 0px;
        float: left
    }

    .linea {
        width: 100%;
        height: 2px;
        background-color: gray;
        float: left
    }

    .img-responsive {
        width: 25px;
        height: 30px;
    }

    .titulos {
        font-size: 15px;
    }

    .titulodoc {
        font-size: 20px;
    }

    .titulodocsec {
        font-size: 20px;
    }

    .cedula-completo table {
        width: 100%;
    }

    .cedula-completo1 table {
        width: 100%;
    }


    .cedula-completo1 > th, td {
        vertical-align: top;
        text-align: center;
        width: 30%;
    }

    .cedula-completo > td {
        text-align: left;
        margin: 0px;
        width: 30%;
    }

    .cedula-completo > th {
        margin: 0px;
        width: 30%;
    }
    .cedula-completo-izquierda {
        float: left;
        width: 100%;
    }

        .cedula-completo-izquierda p {
            font-style: normal;
            font-weight: 100;
            font-size: 18px;
        }

    .cedula-left p {
        font-style: normal;
        font-weight: 100;
        font-size: 15px;
        line-height: 1.0;
        margin-top: 0;
        margin-bottom: 10px;
    }

    .cedula-right p {
        font-style: normal;
        font-weight: 100;
        font-size: 15px;
        line-height: 1.0;
        margin-top: 0;
        margin-bottom: 10px;
    }

    .datosfinales {
        margin-top: 10px;
        text-align: center;
        float: left;
        width: 100%;
    }

        .datosfinales .left {
            text-align: center;
            float: left;
            width: 50%;
            text-transform: uppercase;
        }

        .datosfinales .rigth {
            text-align: center;
            float: left;
            width: 50%;
            text-transform: uppercase;
        }

    h5 {
        margin-top: 0;
        margin-bottom: 8px;
    }

        h5 P {
            line-height: 1.0;
            margin-top: 0;
            margin-bottom: 10px;
        }

    .hechos_observaciones {
        font-size: 15px;
        text-align: left;
    }

    .texto_largos {
        font-weight: normal;
        text-align: justify;
        font-size: 18px;
    }
</style>

<body>
    @foreach (var itemp in Model)
    {
        <div class="container receipt-wrap" id="receipt-wrap">
            <div class="row rowpapa">
                <div class="receipt-main col-xs-12 col-sm-12 col-md-12">
                    <div class="row">
                        <div class="col-xs-2 col-sm-2 col-md-2">
                            <div class="receipt-left">
                            </div>
                        </div>
                        <div class="cedula-completo">
                            <h5 class="titulodoc">CÉDULA DE INFORMACIÓN RECABADA POR LA DQOT</h5>
                            <div class="linea"></div>
                            <h5 class="FOR titulos"><b>ID: @itemp.id_expediente</h5><br>
                        </div>
                        <div class="cedula-left">
                            <br><h5 class="FOR titulos"><b>VISITADURÍA:</b><p> @itemp.visitaduria</p></h5>
                            <h5 class="FRVG titulos"><b>VÍA DE INTERPOSICIÓN:</b><p>@itemp.Via_interpos</p></h5>
                            <h5 class="VI titulos"><b>ABOGADO(A) QUE RECIBE: </b><p>@itemp.id_abogado_recibe</p></h5>
                            <h5 class="FOR titulos"><b>LUGAR DE LOS HECHOS. MUNICIPIO Y ESTADO:</b><p>@itemp.id_lugar_hechos</p></h5>
                        </div>
                        <div class="cedula-right">
                            <br><h5 class="FOR titulos"><b>FECHA DE REGISTRO:</b><p> @itemp.fecha_registro</p></h5>
                            <h5 class="PROG titulos"><b>FECHA DE TURNO A VISITADURÍA:</b><p> @itemp.fecha_turno_vg </p></h5>
                            <h5 class="PROG titulos"><b>SEDE DE REGISTRO:</b><p>@itemp.id_sede</p></h5>
                        </div>
                        <div class="cedula-completo">
                            <br><h5 class="hechos_observaciones"><b>HECHOS:</b><p class="texto_largos">@itemp.hechos</p></h5>
                            <br><h5 class="hechos_observaciones"><b>OBSERVACIONES DQOT:</b><p class="texto_largos">@itemp.observaciones</p></h5>
                            <br><h5 class="titulodocsec">AUTORIDAD(ES)</h5>
                            <div class="linea"></div>
                            <table>
                                <thead>
                                <th>ID AUTORIDAD(ES)</th>
                                <th>ÁMBITO</th>
                                <th>NOMBRE AUTORIDAD(ES)</th>
                                </thead>
                                <tbody>
                                    @foreach (var itemuser in @itemp.listaut)
                                    {
                                        <tr>
                                            <td>@itemuser.idautoridad</td>
                                            <td>@itemuser.ambito</td>
                                            <td>@itemuser.nombre</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>


                        <div class="cedula-completo1">
                            <br><h5 class="titulodocsec">PETICIONARIOS(AS)</h5>
                            <div class="linea"></div>
                            <table>
                                <thead>
                                <th>ID DEL PETICIONARIO(A)</th>
                                <th>TIPO DEL PETICIONARIO(A)</th>
                                <th>NOMBRE DEL PETICIONARIO(A)</th>
                                </thead>
                                <tbody>
                                    @foreach (var itemuser in @itemp.listpeti)
                                    {
                                        <tr>
                                            <td>@itemuser.id</td>
                                            <td>@itemuser.tipopet (a)</td>
                                            <td>@itemuser.nombrepet</td>
                                        </tr>

                                    }
                                </tbody>
                            </table>
                        </div>


                    </div>
                </div>
            </div>
        </div>
    }


</body>