<style>
    .swal2-container {
        z-index: 5001 !important;
    }
    .btn-right {
        position: absolute; /* Posición absoluta para colocar el botón */
        top: 10px; /* Distancia desde arriba */
        right: 10px; /* Distancia desde la derecha */
    }

    .button-parpadeo {
      animation: parpadeo 1s infinite;
    }
    .modal {
      display: none; /* Hidden by default */
      position: fixed; /* Stay in place */
      z-index: 1; /* Sit on top */
      left: 0;
      top: 0;
      width: 100%; /* Full width */
      height: 100%; /* Full height */
      overflow: auto; /* Enable scroll if needed */
      background-color: rgb(0,0,0); /* Fallback color */
      background-color: rgba(0,0,0,0.4); /* Black w/ opacity */
    }

    /* Modal Content/Box */
    .modal-content {
      background-color: #fefefe;
      margin: 3% auto; /* 15% from the top and centered */
      padding: 20px;
      border: 1px solid #888;
      width: 85%; /* Could be more or less, depending on screen size */
      height: 90%;
    }

        /* The Close Button */
    .close {
      color: #aaa;
      float: right;
      font-size: 28px;
      font-weight: bold;
    }

    .close:hover,
    .close:focus {
      color: black;
      text-decoration: none;
      cursor: pointer;
    }

    #frm_altaqueja input, select, textarea {
        width: 100%;
        border-radius: 5px;
        border: solid .5px lightgray;
    }

        #frm_altaqueja input:focus {
            border: solid .5px lightgray;
        }

    #contenedor_Usuarios {
        width: 100%;
        border: solid .5px lightgray;
        min-height: 15%;
        background: white;
        border-radius: 7px;
    }

    #Divpequenios {
        float: left;
        width: 95%;
        border: solid .5px lightgray;
        min-height: 10%;
        background: white;
        border-radius: 7px;
        margin-bottom: 2px;
    }

    .tooltipbloated {
        display: inline;
        position: relative;
        z-index: 999;
    }

    .tooltipbloated-content {
        position: absolute;
        /*background: linear-gradient(135deg, #5bd1d7, #74b9ff );*/
        background-color: rgba(200, 200, 200, 0.8);
        background-size: 100% 100%;
        border-radius: 15px;
        z-index: 9999;
        width: 140px;
        bottom: 100%;
        left: 50%;
        margin-left: -100px;
        padding: 50px 30px;
        text-align: center;
        color: #000000;
        font-weight: bold;
        opacity: 0;
        cursor: default;
        font-size: 0.75em;
        line-height: 1.4;
        pointer-events: none;
        font-family: sans-serif;
        -webkit-transform: scale3d(0.1,0.2,1);
        transform: scale3d(0.1,0.2,1);
        -webkit-transform-origin: 50% 120%;
        transform-origin: 50% 120%;
        -webkit-transition: opacity 0.4s, -webkit-transform 0.4s;
        transition: opacity 0.4s, transform 0.4s;
        -webkit-transition-timing-function: ease, cubic-bezier(0.6,0,0.4,1);
        transition-timing-function: ease, cubic-bezier(0.6,0,0.4,1);
    }

    .tooltipbloated:hover .tooltipbloated-content {
        opacity: 1;
        pointer-events: auto;
        -webkit-transform: scale3d(1,1,1);
        transform: scale3d(1,1,1);
    }
    /***  TOOLTIP BOX  ***/
    .tooltipbox {
        display: inline;
        position: relative;
        z-index: 999;
    }

    /* Trigger text */

    .tooltipbox-item {
        color: black;
        cursor: pointer;
        z-index: 100;
        position: relative;
        display: inline-block;
        font-weight: 700;
        -webkit-transition: background-color 0.3s, color 0.3s, -webkit-transform 0.3s;
        transition: background-color 0.3s, color 0.3s, transform 0.3s;
    }

    .tooltipbox:hover .tooltipbox-item {
        color: black;
        -webkit-transform: translate3d(0,-0.5em,0);
        transform: translate3d(0,-0.5em,0);
    }

    /* Tooltip */

    .tooltipbox-content {
        position: absolute;
        z-index: 99;
        width: 230%;
        left: 45%;
        margin-left: -180px;
        bottom: -5px;
        text-align: left;
        background: #17a2b8;
        opacity: 0;
        font-size: 0.75em;
        text-align: center;
        line-height: 1.5;
        padding: 1.5em;
        color: black;
        border-bottom: 50px solid lightgray;
        cursor: default;
        pointer-events: none;
        border-radius: 5px;
        font-family: sans-serif;
        -webkit-transform: translate3d(0,-0.5em,0);
        transform: translate3d(0,-0.5em,0);
        -webkit-transition: opacity 0.3s, -webkit-transform 0.3s;
        transition: opacity 0.3s, transform 0.3s;
    }

        .tooltipbox-content a {
            color: lightgray;
        }

            .tooltipbox-content a:hover {
                color: lightgray;
            }

    .tooltipbox-text {
        opacity: 0;
        -webkit-transform: translate3d(0,1.5em,0);
        transform: translate3d(0,1.5em,0);
        -webkit-transition: opacity 0.3s, -webkit-transform 0.3s;
        transition: opacity 0.3s, transform 0.3s;
    }

    .tooltipbox:hover .tooltipbox-content,
    .tooltipbox:hover .tooltipbox-text {
        pointer-events: auto;
        opacity: 1;
        -webkit-transform: translate3d(0,0,0);
        transform: translate3d(0,0,0);
    }

    .dummy-text {
        max-width: 1000px;
        font-size: 17px !Important;
    }

    .dummy {
        font-weight: 300;
    }

    .dummy-text p {
        margin-top: 0;
        text-align: center !Important;
        margin-bottom: 0 !important;
    }

    #tablaRecepcion  {
        max-width: 100%;
    }

    #tablaRecepcion input
    {
       max-width:80px;
    }

    #tablaRecepcion thead tr th {
        width: 50px !important;
        margin:0px;
    }

    textarea::placeholder {
        /*color: #999;*/
        color: #d3d3d3;
    }

    .columnas25 {
        width: 25% !important;
    }
</style>

