@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccesor
@using Microsoft.AspNetCore.Identity
<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SistemaIntegralQuejas</title>

    <!-- Google Web Fonts -->
    <link rel="preconnect" href="https://fonts.gstatic.com">
    <script src="//cdn.jsdelivr.net/npm/sweetalert2@11"></script>
     <!-- Font Awesome -->
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="~/lib/bootstrap/dist/css/twitter-bootstrap.css" rel="stylesheet" />
    <!-- Latest compiled and minified CSS -->
    <link href="~/lib/bootstrap/dist/css/bootstrapselect.css" rel="stylesheet" />
    <!-- Datatble -->
    <link href="~/js/vendor/datatables/css/jquery.datatables.min.css" rel="stylesheet" />
    <!-- Libraries Stylesheet -->
    <link href="~/lib/owlcarousel/assets/owl.carousel.min.css" rel="stylesheet">
    <!-- Toast alert -->
    <link href="~/css/toast.css" rel="stylesheet" />
    <!-- DateRange picker-->
    <link href="~/css/style.css" rel="stylesheet">
    <link href="~/js/vendor/bootstrap-daterangepicker/daterangepicker.css" rel="stylesheet" />
    <!-- Summernote -->
    <link href="~/js/vendor/summernote/summernote.css" rel="stylesheet" />
    <!-- Photo Viewer -->
    <link href="~/js/plugins/photoviewer.css" rel="stylesheet" />
    <!-- Mis estilos -->
    <link href="~/css/modalderecha.css" rel="stylesheet" />
    <link href="~/css/fianlizaturno.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/SistemaIntegralQuejas.styles.css" asp-append-version="true" />
    <link href="~/css/semaforo.css" rel="stylesheet" />
</head>
<body>

    <div class="container-fluid">
        <div class="row bg-secondary py-1 px-xl-5">
            <div class="col-lg-6 d-none d-lg-block">
                <div class="d-inline-flex align-items-center h-100">
                    <a class="text-body mr-3" href="#" id="usuarioL"> @HttpContextAccesor.HttpContext?.Session.GetString("Nombre") @HttpContextAccesor.HttpContext?.Session.GetString("Apellidop") @HttpContextAccesor.HttpContext?.Session.GetString("Apellidom")</a>
                    <input id="idusuario" value="@HttpContextAccesor.HttpContext?.Session.GetInt32("IdUsuario")" hidden />
                    <input id="usuario" value="@HttpContextAccesor.HttpContext?.Session.GetString("Username")" hidden />
                    <input id="grupohub" value="@HttpContextAccesor.HttpContext?.Session.GetString("Grupo")" hidden />
                    <input id="areaUser" value="@HttpContextAccesor.HttpContext?.Session.GetString("Area")" hidden />
                    <input id="cargoUser" value="@HttpContextAccesor.HttpContext?.Session.GetString("Cargo")" hidden />
                    <input id="rolUser" value="@HttpContextAccesor.HttpContext?.Session.GetString("Rol")" hidden />
                    <input id="idArea" value="@HttpContextAccesor.HttpContext?.Session.GetString("Idarea")" hidden />
                    <label id="ipAccesible" hidden ></label>

                </div>
            </div>
            <div class="col-lg-6 text-center text-lg-right">
                <div class="d-inline-flex align-items-center">
                    <div class="btn-group">
                        <button type="button" class="btn btn-sm btn-light dropdown-toggle" data-toggle="dropdown">Mi Cuenta</button>
                        <div class="dropdown-menu dropdown-menu-right">
                            <a class="dropdown-item" asp-controller="Login" asp-action="CerrarSesion" type="button">Cerrar sesión</a>
                        </div>
                    </div>
                    @if (User.IsInRole("SUPERADMINISTRADOR"))
                    {
                        <div class="btn-group mx-2">
                            <button type="button" class="btn btn-sm btn-light dropdown-toggle" data-toggle="dropdown">Admin</button>
                            <div class="dropdown-menu dropdown-menu-right">
                                <button class="dropdown-item" type="button">Panel Administrador</button>
                            </div>
                        </div>
                        <div class="btn-group">
                            <button type="button" class="btn btn-sm btn-light dropdown-toggle" data-toggle="dropdown">Sistema</button>
                            <div class="dropdown-menu dropdown-menu-right">
                                <button class="dropdown-item" type="button">Productivo</button>
                                <button class="dropdown-item" type="button">Prueba</button>
                            </div>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
    <!-- Topbar End -->
    <!-- Navbar Start -->
    <div class="container-fluid bg-dark mb-30">
        <!---->
        <div class="row px-xl-5">
            <div class="col-lg-3 d-none d-lg-block">
                <a class="btn d-flex align-items-center justify-content-between  w-100" data-toggle="collapse" href="#" style="height: 65px; padding: 0 30px; background-color: #17A2B8 !important;">
                    <h6 class="text-light m-0"><i class="fa fa-bars mr-2"></i>Sistema Integral de Quejas</h6>
                    @*<i class="fa fa-angle-down text-light"></i>*@
                </a>
                @if (User.IsInRole("SUPERADMINISTRADOR"))
                {
                    <nav class="collapse position-absolute navbar navbar-vertical navbar-light align-items-start p-0 bg-light" id="navbar-vertical" style="width: calc(100% - 30px); z-index: 999;">
                        <div class="navbar-nav w-100">
                            <a href="" class="nav-item nav-link">Sistema Actual</a>
                            <a href="" class="nav-item nav-link">Sistema Anterior</a>
                        </div>
                    </nav>
                }
            </div>
            <div class="col-lg-9">
                <nav class="navbar navbar-expand-lg bg-dark navbar-dark py-3 py-lg-0 px-0">
                    <a href="" class="text-decoration-none d-block d-lg-none">
                    </a>
                    <button type="button" class="navbar-toggler" data-toggle="collapse" data-target="#navbarCollapse">
                        <span class="navbar-toggler-icon"></span>
                    </button>
                    <div class="collapse navbar-collapse justify-content-between" id="navbarCollapse">
                        <div class="navbar-nav mr-auto py-0" id="menuD">
                            <!--Menú dinámico-->
                            @if (User.IsInRole("ADMIN_DQOT") || User.IsInRole("VA_DQOT"))
                            {

                                <div class="btn-group">
                                    <button type="button" class="btn btndropdown dropdown-toggle" data-toggle="dropdown"> DQOT </button>
                                    <div class="dropdown-menu dropoption dropdown-menu-right dropdown-menu menu-maximo">

                                        @if (User.IsInRole("ADMIN_DQOT"))
                                        {
                                            <li class="dropdown-submenu">
                                            <li><a class="dropdown-item" asp-controller="Expediente" asp-action="index">Alta de escrito inicial</a></li>
                                            </li>
                                            <li class="dropdown-submenu">
                                            <li><a class="dropdown-item" asp-controller="Home" asp-action="Index_ADMIN_DQOT">Admin DQOT</a></li>
                                            </li>
                                            <li class="dropdown-submenu">
                                            <li><a class="dropdown-item" asp-controller="Home" asp-action="Index">Tomar turno</a></li>
                                            </li>
                                            <li class="dropdown-submenu">
                                            <li><a class="dropdown-item" asp-controller="Expediente" asp-action="BuscadorFormatos">Bucador de ID´s</a></li>
                                            </li>

                                    }else if ( User.IsInRole("VA_DQOT"))
                                        {
                                            <li class="dropdown-submenu">
                                            <li><a class="dropdown-item" asp-controller="Expediente" asp-action="index">Alta de escrito inicial</a></li>
                                            </li>
                                            <li class="dropdown-submenu">
                                            <li><a class="dropdown-item" asp-controller="Home" asp-action="Index">Tomar turno</a></li>
                                            </li>
                                            <li class="dropdown-submenu">
                                            <li><a class="dropdown-item" asp-controller="Expediente" asp-action="BuscadorFormatos">Bucador de ID´s</a></li>
                                            </li>
                                        }


                                    </div>
                                </div>
                            }
                            @if (User.IsInRole("VG"))
                            {
                                <div class="btn-group">
                                    <button type="button" class="btn btndropdown dropdown-toggle" data-toggle="dropdown"> VG </button>
                                    <div class="dropdown-menu dropoption dropdown-menu-right dropdown-menu menu-maximo">

                                        @if (User.IsInRole("VG"))
                                        {
                                            <li class="dropdown-submenu">
                                            <li><a class="dropdown-item" asp-controller="Expediente" asp-action="Calificacion">Aceptar/Rechazar ID´s de queja</a></li>
                                            </li>
                                            <li class="dropdown-submenu">
                                            <li><a class="dropdown-item" asp-controller="Expediente" asp-action="Calificacion">Turnado de ID´s de queja</a></li>
                                            </li>
                                            <li class="dropdown-submenu">
                                            <li><a class="dropdown-item" asp-controller="Expediente" asp-action="VistaCalificacion">Calificación de una queja</a></li>
                                            </li>
                                        }
                                    </div>
                                </div>
                            }


                            <!--Fin Menú Dinámico-->
                        </div>

                        <div class="btn-container" style="margin-top:1.5%">
                            <label class="switch btn-color-mode-switch">
                                <input type="checkbox" class="chk_userActivo" name="color_mode" id="color_mode">
                                <label for="color_mode" data-on="Activo" data-off="Inactivo" class="lblchk btn-color-mode-switch-inner"></label>
                            </label>
                        </div>

                    </div>
                </nav>
            </div>
        </div>
    </div>
    <!-- Navbar End -->
    <div class="alert alert-warning" id="alertUltimoConectado" role="alert">
      Eres el último usuario conectado para atender los turnos de la DQOT
    </div>
    <div class="alert alert-danger" id="alertNoHayConectados" role="alert">
        No hay usuarios conectados para atender los turnos de la DQOT
    </div>
    <!-- Breadcrumb Start -->
    <div class="container-fluid mt-4">
        <!--   boton flotante finalizar queja-->
        <input id="idmodulo_finalizar" hidden />
        <input id="idTurno_finalizar" hidden />
        <div class="hero draggable" id="hero6">
        </div>
        <!--   Fin boton flotante finalizar queja-->

        <div class="row px-xl-5">
            <div class="col-12">
                <nav class="breadcrumb bg-light mb-30">
                    <a class="breadcrumb-item text-dark" href="#">Inicio</a>
                    <a class="breadcrumb-item text-dark" href="#">Tarea</a>
                    <span class="breadcrumb-item active">Acción</span>
                </nav>
            </div>
        </div>
    </div>
    <!-- Breadcrumb End -->

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

