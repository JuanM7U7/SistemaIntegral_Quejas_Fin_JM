        <div class="row px-xl-5 pt-5">
            <div class="col-lg-4 col-md-12 mb-5 pr-3 pr-xl-5">
                <img width="80" src="~/img/logo_cdh.png" alt="">
                <p class="mt-2">En la CDH PUEBLA</p>
                <p>¡Protegémos tus Derechos!</p>
            </div>
            <div class="col-lg-8 col-md-12">
                <div class="row">
                    <div class="col-md-4 mb-5">
                        <h5 class="text-secondary text-uppercase mb-4">CDH PUEBLA</h5>
                        <div class="d-flex flex-column justify-content-start">
                            <a class="text-secondary mb-2" target="_blank" href="https://www.cdhpuebla.org.mx/v1/index.php/cdh-puebla/la-cdhpuebla"><i class="fa fa-angle-right mr-2"></i>Misión</a>
                            <a class="text-secondary mb-2" target="_blank" href="https://www.cdhpuebla.org.mx/v1/index.php/cdh-puebla/la-cdhpuebla"><i class="fa fa-angle-right mr-2"></i>Visión</a>
                            <a class="text-secondary mb-2" target="_blank" href="https://www.cdhpuebla.org.mx/v1/index.php/antecedentes"><i class="fa fa-angle-right mr-2"></i>Antecedentes</a>
                            <a class="text-secondary mb-2" target="_blank" href="https://www.cdhpuebla.org.mx/v1/index.php/normatividad"><i class="fa fa-angle-right mr-2"></i>Normatividad</a>
                            <a class="text-secondary mb-2" target="_blank" href="https://transparencia.cdhpuebla.org.mx/images/fraccionI/PIG-I/"><i class="fa fa-angle-right mr-2"></i>Norma-nmx-25-2015</a>
                        </div>
                    </div>
                    <div class="col-md-4 mb-5">
                        <h5 class="text-secondary text-uppercase mb-4">MI CUENTA</h5>
                        <div class="d-flex flex-column justify-content-start">
                            <a class="text-secondary mb-2" href="#"><i class="fa fa-angle-right mr-2"></i>Mis Datos</a>
                            @*<a class="text-secondary mb-2" href="#"><i class="fa fa-angle-right mr-2"></i>Iniciar sesión</a>*@
                            @*<a class="text-secondary mb-2" href="#"><i class="fa fa-angle-right mr-2"></i>Mis expedientes</a>*@
                        </div>
                    </div>
                    <div class="col-md-4 mb-5">
                        <h5 class="text-secondary text-uppercase mb-4">SOPORTE TÉCNICO</h5>
                        <p>informatica@cdhpuebla.org.mx</p>
                        <h6 class="text-secondary text-uppercase mt-4 mb-3">Siguenos en redes sociales</h6>
                        <div class="d-flex">
                            <a class="btn btn-primary btn-square mr-2" target="_blank" href="https://twitter.com/cdhpuebla?s=11&t=dUbJX41c6WdT0S9QTZDYjA"><i class="fab fa-twitter"></i></a>
                            <a class="btn btn-primary btn-square mr-2" target="_blank" href="https://www.facebook.com/CDHEPuebla"><i class="fab fa-facebook-f"></i></a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row border-top mx-xl-5 py-4" style="border-color: rgba(256, 256, 256, .1) !important;">
            <div class="col-md-6 px-xl-0">
                <p class="mb-md-0 text-center text-md-left text-secondary">
                    &copy; <a class="text-primary" href="#">Copyright</a>. 2022 Todos los derechos reservados
                    <a class="text-primary" target="_blank" href="https://www.cdhpuebla.org.mx/v1/"> CDH PUEBLA</a>

                </p>
            </div>
            <div class="col-md-6 px-xl-0 text-center text-md-right">
                <img class="img-fluid" src="~/img/payments.png" alt="">
            </div>
        </div>
    <!-- Back to Top -->
    <a href="#" class="btn btn-primary back-to-top"><i class="fa fa-angle-double-up"></i></a>
    </div>
    <!-- Footer End -->

    <!-- Jquery -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/plugins/popper.js"></script>
    <script src="~/js/plugins/tooltip.js"></script>
