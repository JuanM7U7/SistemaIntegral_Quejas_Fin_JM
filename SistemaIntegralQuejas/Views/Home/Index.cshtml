                    <div class="col-4">
                        <div class="example">
                            <input class="form-control btn-rounded input-daterange-datepicker" type="text" name="daterange">
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="btn-group submitter-group float-left">
                            <div class="input-group-prepend">
