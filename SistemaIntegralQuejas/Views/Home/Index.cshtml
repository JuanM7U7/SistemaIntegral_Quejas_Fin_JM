            </div>

            <!-- Inicio Tabla turnos --> 
            <div class="table-responsive">
                <table id="tblTurnosPendientesVAQ" class="display" style="min-width: 845px">
                    <thead>
                        <tr>
                            <th>TURNO</th>
						    <th>FECHA SOLICITUD</th>
						    <th>HORA SOLICITUD</th>
						    <th>HORA FINALIZADO</th>
						    <th>DURACIÓN DE ATENCIÓN</th>
						    <th>TIPO</th>
						    <th>PETICIONARIO</th>
						    <th>STATUS</th>
						    <th>ATENDER</th>
                        </tr>
                    </thead>
                    <tbody>
                       @* <tr>
                            <td>1</td>
                            <td>14/05/2023 09:31:00</td>
                            <td>09:31:00</td>
                            <td>09:31:00</td>
