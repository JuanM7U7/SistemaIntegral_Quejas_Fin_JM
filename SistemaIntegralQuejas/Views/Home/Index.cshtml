    </div>

</div>

@section Scripts
{
    <script src="~/js/function_vadqot.js"></script>
    <script src="~/js/turnoclient.js"></script>
}

<!-- *******************************************   MODALES  ************************************************** -->

<!-- Modal Selección Módulos-->

<!-- Scrollable modal -->
<div class="modal fade " id="modal_atender" role="dialog">
	<div class="modal-dialog ">
		<div class="modal-content registro">
			<!-- Modal Header -->
			<div class="modal-header">
				<h4 class="modal-title" id="myModalLabel">Selecciona Módulo de Atención
				<button type="button" class="close" data-dismiss="modal">
						<span aria-hidden="true" onclick="CierraPopup()">×</span>
					<span class="sr-only">Close</span>
				</button>
				</h4>
			</div>

			<!-- Modal Body -->
			<div class="modal-body">
				<p class="statusMsg"></p>
					<input id="idturno" hidden/>
				<form class="checkin" role="form" id="formModulos">


				</form>
			</div>

			<!-- Modal Footer -->
			<div class="modal-footer">
				<button type="button" class="btn btn-default" data-dismiss="modal" onclick="CierraPopup()">Cerrar</button>
				<button type="button" class="btn btn-primary submitBtn" onclick="updateStatusModulosDqot()" id="save">Aceptar</button>
			</div>
		</div>
	</div>
</div>
<!--  FIN Modal Selección Módulos-->